generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  RESIDENT
  PRO
}

enum ResidentStatus {
  PENDING
  ACTIVE
  ARCHIVED
  REJECTED
}

enum FaultPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FaultStatus {
  REPORTED
  ASSIGNED
  IN_PROGRESS
  FIXED
  ARCHIVED
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  BLOCKED
  COMPLETED
  ARCHIVED
}

enum ParkingLotStatus {
  OPEN
  SHORTLISTED
  PROMOTED
  ARCHIVED
}

enum PRCommStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  ARCHIVED
}

enum AssetType {
  POLE
  MANHOLE
  TRANSFORMER
  VALVE
  HYDRANT
  OTHER
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  name           String
  passwordHash   String?
  googleSub      String?          @unique
  isActive       Boolean          @default(true)
  role           Role
  residentStatus ResidentStatus?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Resident {
  id           String         @id @default(uuid())
  name         String
  standNo      String
  email        String?        @unique
  phone        String?
  profilePic   String?
  addressLine1 String?
  suburb       String?
  city         String?
  ward         String?
  latitude     Float?
  longitude    Float?
  notes        String?
  status       ResidentStatus
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Fault {
  id                String        @id @default(uuid())
  title             String
  description       String
  reporterEmail     String
  category          String
  priority          FaultPriority
  status            FaultStatus
  latitude          Float?
  longitude         Float?
  locationText      String?
  photo             String?
  residentId        String?
  assignedAdminId   String?
  municipalityEmail String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model ParkingLot {
  id            String            @id @default(uuid())
  title         String
  justification String
  priority      String
  status        ParkingLotStatus
  threshold     Int               @default(10)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ParkingLotVote {
  id           String   @id @default(uuid())
  parkingLotId String
  userEmail    String
  createdAt    DateTime @default(now())

  @@unique([parkingLotId, userEmail])
}

model Project {
  id            String        @id @default(uuid())
  title         String
  description   String?
  budget        Decimal?
  timelineStart DateTime?
  timelineEnd   DateTime?
  status        ProjectStatus
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ProjectTask {
  id          String   @id @default(uuid())
  projectId   String
  title       String
  description String?
  assigneeId  String?
  status      String
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PRComm {
  id          String       @id @default(uuid())
  headline    String
  body        String
  channel     String
  status      PRCommStatus
  appCount    Int          @default(0)
  createdById String?
  sentById    String?
  sentAt      DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model PRCommApproval {
  id        String   @id @default(uuid())
  prCommId  String
  userEmail String
  createdAt DateTime @default(now())

  @@unique([prCommId, userEmail])
}

model SocialCalendar {
  id          String   @id @default(uuid())
  holidayName String
  date        DateTime
  category    String
  postPlan    String?
  mediaRef    String?
}

model Donor {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  tier         String
  interests    String?
  totalDonated Decimal  @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Donation {
  id        String   @id @default(uuid())
  donorId   String
  projectId String?
  amount    Decimal
  date      DateTime
  createdAt DateTime @default(now())
}

model VaultAsset {
  id          String   @id @default(uuid())
  assetName   String
  filePath    String
  category    String
  description String?
  visibility  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HelpArticle {
  id           String   @id @default(uuid())
  topic        String
  category     String
  instructions String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MeetingMinute {
  id          String   @id @default(uuid())
  title       String
  meetingAt   DateTime
  attendees   String
  notes       String
  attachments String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MeetingAction {
  id              String   @id @default(uuid())
  minuteId        String
  title           String
  ownerEmail      String?
  linkedFaultId   String?
  linkedProjectId String?
  status          String
  dueDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model InfrastructureAsset {
  id        String    @id @default(uuid())
  assetName String
  assetType AssetType
  condition String
  street    String
  latitude  Float
  longitude Float
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model AssetPhoto {
  id        String   @id @default(uuid())
  assetId   String
  filePath  String
  caption   String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  actorEmail  String
  action      String
  entityType  String
  entityId    String
  description String?
  createdAt   DateTime @default(now())
}
